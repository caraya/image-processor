{
    "tags": {
        "allowUnknownTags": ["category"]
    },
    "source": {
        "include": ["./dist"],
        "includePattern": ".js$",
        "excludePattern": "(node_modules/|docs)"
    },
    "plugins": [
        "plugins/markdown",
        "jsdoc-mermaid",
        "node_modules/better-docs/category"
    ],
    "opts": {
        "encoding": "utf8",
        "destination": "docs/",
        "readme": "EXPLAINER.md",
        "recurse": true,
        "verbose": true,
        "tutorials": "",
        "template": "./node_modules/better-docs"
    },
    "templates": {
        "cleverLinks": false,
        "monospaceLinks": false,
        "search": true,
        "default": {
            "staticFiles": {
              "include": [
                  "./docs-src/statics"
              ]
            }
        },
        "better-docs": {
            "name": "Sample Documentation",
            "logo": "images/logo.png",
            "title": "",
            "css": "style.css",
            "trackingCode": "",
	    "hideGenerator": false,
            "navLinks": [
                {
                    "label": "Better Docs",
                    "href": "https://github.com/SoftwareBrothers/admin-bro"
                }
            ]
        }
    }
}